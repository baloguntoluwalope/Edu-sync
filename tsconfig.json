{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
   "typeRoots": ["./node_modules/@types", "./src/shared/types"]
  },
  "ts-node": {
    "files": true,
    "transpileOnly": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}